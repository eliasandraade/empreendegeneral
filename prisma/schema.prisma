// Schema Prisma — Empreende General
// Entidades principais do sistema conforme CLAUDE.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum UserRole {
  USER
  ENTREPRENEUR
  ADMIN
}

enum BusinessStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReportReason {
  INAPPROPRIATE_CONTENT
  WRONG_INFORMATION
  SPAM
  DUPLICATE
  OTHER
}

// ─── Auth.js (NextAuth v5) — Tabelas obrigatórias ────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Usuário ──────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(USER)
  phone         String?
  consentAt     DateTime? // consentimento LGPD

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft delete

  accounts   Account[]
  sessions   Session[]
  businesses Business[]
  reviews    Review[]
  favorites  Favorite[]
  reports    Report[]
}

// ─── Categoria ────────────────────────────────────────────

model Category {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String?
  icon        String? // nome do ícone Lucide ou URL

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businesses Business[]
}

// ─── Negócio ──────────────────────────────────────────────

model Business {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  description String?        @db.Text
  status      BusinessStatus @default(PENDING)

  // Contato
  phone     String?
  website   String?
  instagram String?
  whatsapp  String?

  // Endereço e geolocalização
  address   String?
  city      String?
  state     String?
  zipCode   String?
  latitude  Float?
  longitude Float?

  // Proprietário
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  // Categoria
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  // Destaque na home
  featured Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft delete

  images     BusinessImage[]
  reviews    Review[]
  favorites  Favorite[]
  highlights Highlight[]
  reports    Report[]
}

// ─── Imagem do negócio ───────────────────────────────────

model BusinessImage {
  id        String  @id @default(cuid())
  url       String // URL Cloudinary
  publicId  String // ID público Cloudinary (para exclusão)
  alt       String?
  isPrimary Boolean @default(false)
  order     Int     @default(0)

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ─── Avaliação ────────────────────────────────────────────

model Review {
  id      String  @id @default(cuid())
  rating  Int // 1 a 5
  comment String? @db.Text

  userId     String
  user       User     @relation(fields: [userId], references: [id])
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  deletedAt DateTime? // removível apenas por admin

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reply   ReviewReply?
  reports Report[]

  @@unique([userId, businessId]) // um por usuário por negócio
}

// ─── Resposta do empreendedor ─────────────────────────────

model ReviewReply {
  id      String @id @default(cuid())
  content String @db.Text

  reviewId String @unique
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Favorito ─────────────────────────────────────────────

model Favorite {
  id String @id @default(cuid())

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, businessId])
}

// ─── Lead (captura de interesse) ─────────────────────────

model Lead {
  id      String  @id @default(cuid())
  name    String
  email   String
  phone   String?
  message String? @db.Text
  source  String? // origem do lead

  createdAt DateTime @default(now())
}

// ─── Artigo / Conteúdo editorial ─────────────────────────

model Article {
  id        String  @id @default(cuid())
  title     String
  slug      String  @unique
  content   String  @db.Text
  excerpt   String?
  coverUrl  String? // URL Cloudinary
  published Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

// ─── Destaque na home ────────────────────────────────────

model Highlight {
  id         String    @id @default(cuid())
  businessId String
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  order      Int       @default(0)
  activeFrom DateTime?
  activeTo   DateTime?

  createdAt DateTime @default(now())
}

// ─── Denúncia ─────────────────────────────────────────────

model Report {
  id     String       @id @default(cuid())
  reason ReportReason
  notes  String?      @db.Text

  reporterId String
  reporter   User   @relation(fields: [reporterId], references: [id])

  // Alvo: negócio OU avaliação (pelo menos um deve estar preenchido)
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  reviewId   String?
  review     Review?   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  resolved   Boolean   @default(false)
  resolvedAt DateTime?

  createdAt DateTime @default(now())
}
